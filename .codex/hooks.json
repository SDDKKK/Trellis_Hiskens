{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 .codex/hooks/session-start.py",
            "timeout": 15,
            "statusMessage": "Loading Trellis context..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 .codex/hooks/post-tool-use.py",
            "timeout": 15,
            "statusMessage": "Processing tool output..."
          }
        ]
      }
    ]
  }
}
