+    fs.writeFileSync(path.join(taskDir, FILE_NAMES.PRD), prdContent, "utf-8");
+    fs.writeFileSync(
+      path.join(cwd, PATHS.CURRENT_TASK_FILE),
+      `${PATHS.TASKS}/${taskName}`,
+      "utf-8",
